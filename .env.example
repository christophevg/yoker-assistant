# yoker-assistant email account configuration.
# These configure the mailbox the assistant polls via simple-email-gw.
# Copy this file to .env and fill in the values for your account.
#
# .env is for email-account credentials only. Backend API keys (for a cloud
# provider) live in ~/.yoker.toml, not here. Neither file is committed.

EMAIL_IMAP_HOST=imap.example.com
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_USERNAME=assistant@example.com
EMAIL_PASSWORD=your-app-password-here
# Reply safety boundary (simple-email-gw): the assistant may ONLY reply to
# addresses in this whitelist. Set to the single owner address. Leaving it
# broad allows the agent to reply to arbitrary senders.
EMAIL_RECIPIENT_WHITELIST_ADDRESSES=owner@example.com